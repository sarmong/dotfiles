#!/usr/bin/env bash

launcher="${1:-rofi}"

PIPE="$(mktemp -u /tmp/sessionsfifo.XXXXXX)"
mkfifo "$PIPE"
TMPFILE="$(mktemp)"
ACTION="default"

main() {
  get_all_sessions &

  select_session
  selected_session="$SELECTED"

  rm "$PIPE" "$TMPFILE"

  if [ -z "$selected_session" ]; then
    exit
  fi

  if [ "$ACTION" = "new_window" ]; then
    open_new_window "$selected_session"
  else
    switch_last_window "$selected_session"
  fi
}

open_new_window() {
  selected="$1"
  if tmux has-session -t "$selected" 2>/dev/null; then
    "$TERMINAL" -e "$SHELL" -c "tmux attach-session -t $selected ; $SHELL"
  else
    "$TERMINAL" --directory "$selected" -e "$SHELL" -c "workplace ; $SHELL"
  fi
}

switch_last_window() {
  selected="$1"
  session_name="$(basename "$selected" | tr '.:' '_')"

  tmux has-session -t "$session_name" 2>/dev/null || workplace "$selected"

  ## Find window where this session is active
  client_info=$(tmux list-clients -F "#{client_pid} #{client_tty} #{client_session}" |
    awk -v s="$session_name" '$3 == s { print; exit }')
  ## If not active, get most recent client
  if [ -z "$client_info" ]; then
    client_info=$(tmux display-message -p "#{client_pid} #{client_tty} #{client_session}")
  fi

  pid=$(printf '%s' "$client_info" | awk '{print $1}')
  client_tty=$(printf '%s' "$client_info" | awk '{print $2}')

  window_pid_map=$(wmctrl -l -p | awk '{print $3, $1}')
  while [ -n "$pid" ] && [ "$pid" != 1 ]; do
    wid=$(printf '%s\n' "$window_pid_map" | awk -v p="$pid" '$1==p{print $2; exit}')
    [ -n "$wid" ] && xdotool windowactivate "$wid" && break
    pid=$(awk '/^PPid:/{print $2; exit}' /proc/"$pid"/status 2>/dev/null)
  done

  tmux switch-client -c "$client_tty" -t "$session_name"
}

get_all_sessions() {
  work_projects=$(find "$HOME/docs/work" "$HOME/docs/tech" -mindepth 1 -maxdepth 1 -type d)
  personal="$XDG_DOTFILES_DIR\n$XDG_NC_DIR/Vault"

  dirs="$work_projects\n$personal"

  sessions_for_display=$(tmux ls -F '#{session_last_attached} #{session_name}' | sort -k 1 -rn | cut -d ' ' -f 2-)
  opened_sessions=$sessions_for_display

  active_win_pid=$(xdo pid 2>/dev/null)
  active_win_name=""

  if [ -n "$active_win_pid" ]; then
    active_win_name=$(awk '/^Name:/{print $2; exit}' "/proc/$active_win_pid/status" 2>/dev/null)
  fi

  if [ "$active_win_name" = "$TERMINAL" ]; then
    while read -r client_pid client_session; do
      if is_child "$client_pid" "$active_win_pid"; then
        echo "Excluding active session: $client_session" >/dev/tty &
        sessions_for_display=$(echo "$sessions_for_display" | grep -Fxv "$client_session")
        break
      fi
    done < <(tmux list-clients -F "#{client_pid} #{client_session}")
  fi

  {
    echo "$sessions_for_display"
    printf '%b' "$dirs" | rofi-frecency get "sessions" |
      while IFS= read -r path; do
        name=${path##*/}
        name=${name//[.:]/_}
        for exclude in $opened_sessions; do
          [ "$name" = "$exclude" ] && continue 2
        done
        printf '%s\n' "$path"
      done
  } | tee -a "$TMPFILE" >>"$PIPE"
}

select_session() {
  if [ "$launcher" = "fzf" ]; then
    selected=$(cat "$PIPE" | fzf -d "/" --with-nth -1 --bind "ctrl-x:execute(tmux kill-session -t {})")

    if [ -z "$selected" ]; then
      return 0
    fi
  else
    if [ -n "$TMUX" ]; then
      window_id="$(xdotool getactivewindow)"
      rofi_flags="-w $window_id"
    fi

    selected_idx=$(cat "$PIPE" | xargs -I {} -n 1 basename {} | rofi -dmenu -i -format d $rofi_flags -kb-accept-alt "" -kb-accept-custom "" -kb-custom-1 "shift+Return" -kb-custom-2 "ctrl+Return") ## without using {} xargs splits by spaces too
    rofi_exit=$?

    if [ -z "$selected_idx" ] || [ "$selected_idx" -lt 1 ]; then
      return 0
    fi

    selected=$(sed '/^$/d' "$TMPFILE" | sed -n "${selected_idx}p") ## There may be empty leading line for some reason

    if [ "$rofi_exit" = 10 ] || [ "$rofi_exit" = 11 ]; then
      ACTION="new_window"
    fi
  fi

  ## if not eq -- that means it is a path and not a tmux session name
  if [ "$(basename "$selected")" != "$selected" ]; then
    rofi-frecency update "sessions" "$selected"
  fi

  if [ "$(git -C "$selected" rev-parse --is-bare-repository)" = "true" ]; then #TODO: errors if tmux here
    cd "$selected" || return
    wt_list=$(wt list | tail -n +4)

    if [ "$launcher" = "fzf" ]; then
      selected_line=$(printf '%s\n' "$wt_list" | fzf)
      if [ -z "$selected_line" ]; then
        return 0
      fi
    else
      selected_idx=$(printf '%s\n' "$wt_list" | rofi -dmenu -i -format d)
      if [ -z "$selected_idx" ]; then
        return 0
      fi
      selected_line=$(printf '%s\n' "$wt_list" | sed -n "${selected_idx}p")
    fi

    slot=$(printf '%s\n' "$selected_line" | awk '{print ($1 == "*" ? $2 : $1)}')
    selected="$selected/$slot"
  fi

  SELECTED="$selected"
}

is_child() {
  child_id=$1
  parent_id=$2

  while [ "$child_id" != 1 ]; do
    if [ "$child_id" = "$parent_id" ]; then
      return 0
    fi
    child_id=$(awk '/^PPid:/{print $2; exit}' /proc/"$child_id"/status 2>/dev/null) || break
  done

  return 1
}

main "$@"
